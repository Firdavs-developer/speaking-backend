# Copy to .env and adjust. The .env file is read automatically by settings.py.

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Admin password used to manage speaking questions (matches the frontend).
ADMIN_PASSWORD=admin123

# Comma-separated origins allowed to call the API (the Next.js frontend).
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
