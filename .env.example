# Copy to .env and adjust. The .env file is read automatically by settings.py.

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Admin password used to manage speaking questions (matches the frontend).
ADMIN_PASSWORD=admin123

# Comma-separated origins allowed to call the API (the Next.js frontend).
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Email — sends the 6-digit registration / password-reset codes.
# Leave EMAIL_HOST_USER empty to print codes to the console (dev only).
# For Gmail: create an App Password (https://myaccount.google.com/apppasswords)
# and use it as EMAIL_HOST_PASSWORD.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Speaking Practice <your-email@gmail.com>
